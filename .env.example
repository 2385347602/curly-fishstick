# Umami 统计配置
PUBLIC_UMAMI_WEBSITE_ID=your-website-id
PUBLIC_UMAMI_API_URL=https://cloud.umami.is
UMAMI_AUTH_TOKEN=your-auth-token

# Giscus 评论配置
GISCUS_REPO=owner/repo
GISCUS_REPO_ID=R_kgDOxxxxxx
GISCUS_CATEGORY_ID=DIC_xxxxxx

# Memos API 配置
MEMOS_API_URL=https://your-memos-domain.com
MEMOS_USER_ID=1

# 音乐播放器配置（可选）
MUSIC_TRACKS_JSON=/data/music-tracks.json
