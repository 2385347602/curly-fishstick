/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 1rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  // 主色调 - 更鲜艳的青蓝色
  --primary: oklch(0.65 0.18 var(--hue)) oklch(0.70 0.18 var(--hue))

  // 页面背景 - 更柔和的浅色/深色
  --page-bg: oklch(0.98 0.005 var(--hue)) oklch(0.14 0.010 var(--hue))

  // 卡片背景
  --card-bg: white oklch(0.20 0.012 var(--hue))

  // 按钮内容颜色
  --btn-content: oklch(0.50 0.15 var(--hue)) oklch(0.70 0.12 var(--hue))

  // 常规按钮背景
  --btn-regular-bg: oklch(0.96 0.020 var(--hue)) oklch(0.30 0.030 var(--hue))
  --btn-regular-bg-hover: oklch(0.92 0.040 var(--hue)) oklch(0.35 0.035 var(--hue))
  --btn-regular-bg-active: oklch(0.88 0.060 var(--hue)) oklch(0.40 0.040 var(--hue))

  // 简约按钮背景
  --btn-plain-bg-hover: oklch(0.97 0.015 var(--hue)) oklch(0.28 0.025 var(--hue))
  --btn-plain-bg-active: oklch(0.99 0.008 var(--hue)) oklch(0.25 0.020 var(--hue))

  // 卡片按钮背景
  --btn-card-bg-hover: oklch(0.99 0.003 var(--hue)) oklch(0.28 0.025 var(--hue))
  --btn-card-bg-active: oklch(0.92 0.025 var(--hue)) oklch(0.33 0.030 var(--hue))

  // 进入按钮背景
  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  // 深色文本
  --deep-text: oklch(0.20 0.015 var(--hue))

  // 标题激活状态
  --title-active: oklch(0.55 0.12 var(--hue))

  // 分隔线
  --line-divider: black(0.06) white(0.06)
  --line-color: black(0.08) white(0.08)
  --meta-divider: black(0.15) white(0.15)

  // 行内代码
  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)

  // 选中文本背景
  --selection-bg: oklch(0.92 0.040 var(--hue)) oklch(0.38 0.070 var(--hue))

  // 代码块
  --codeblock-selection: oklch(0.38 0.070 var(--hue))
  --codeblock-bg: oklch(0.15 0.012 var(--hue)) oklch(0.15 0.012 var(--hue))
  --codeblock-topbar-bg: oklch(0.25 0.018 var(--hue)) oklch(0.10 0.012 var(--hue))

  // 许可证块背景
  --license-block-bg: black(0.02) var(--codeblock-bg)

  // 链接样式
  --link-underline: oklch(0.95 0.030 var(--hue)) oklch(0.38 0.070 var(--hue))
  --link-hover: oklch(0.97 0.020 var(--hue)) oklch(0.38 0.070 var(--hue))
  --link-active: oklch(0.92 0.040 var(--hue)) oklch(0.33 0.060 var(--hue))

  // 浮动面板背景
  --float-panel-bg: white oklch(0.17 0.012 var(--hue))

  // 滚动条
  --scrollbar-bg-light: black(0.35)
  --scrollbar-bg-hover-light: black(0.45)
  --scrollbar-bg-active-light: black(0.55)

  --scrollbar-bg-dark: white(0.35)
  --scrollbar-bg-hover-dark: white(0.45)
  --scrollbar-bg-active-dark: white(0.55)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  // 颜色选择条
  --color-selection-bar: rainbow-light rainbow-dark

  // 图标显示
  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  // 提示框颜色
  --admonitions-color-tip: oklch(0.70 0.14 180) oklch(0.75 0.14 180)
  --admonitions-color-note: oklch(0.70 0.14 250) oklch(0.75 0.14 250)
  --admonitions-color-important: oklch(0.70 0.14 310) oklch(0.75 0.14 310)
  --admonitions-color-warning: oklch(0.70 0.14 60) oklch(0.75 0.14 60)
  --admonitions-color-caution: oklch(0.60 0.20 25) oklch(0.65 0.20 25)

  // 目录样式
  --toc-badge-bg: oklch(0.91 0.045 var(--hue)) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.94 0.012 var(--hue)) oklch(0.20 0.018 var(--hue))
  --toc-btn-active: oklch(0.92 0.012 var(--hue)) oklch(0.23 0.018 var(--hue))
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.68 0.120 var(--hue)) oklch(0.33 0.060 var(--hue))
})
